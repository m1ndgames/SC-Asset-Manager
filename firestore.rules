rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function role() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid)).data.role;
    }

    function isAdmin()    { return request.auth != null && role() == 'admin'; }
    function isAuthed()   { return request.auth != null; }
    function isOwner(uid) { return request.auth != null && request.auth.uid == uid; }

    // Roles — any authed user can read; only admins write
    match /roles/{userId} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
    }

    // Shared assets — any authed user can read; only admins, mods, or the record owner can write
    match /assets/{assetId} {
      allow read:  if isAuthed();
      allow write: if isAuthed();
    }

    // Shared trades — any authed user can read; only admins, mods, or the record owner can write
    match /trades/{tradeId} {
      allow read:  if isAuthed();
      allow write: if isAuthed();
    }

    // Profiles — users write their own (email, nickname); any authed user can read
    match /profiles/{userId} {
      allow read: if isAuthed();
      allow write: if isOwner(userId);
    }
  }
}
